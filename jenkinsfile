pipeline {
    agent any
    stages {
        stage('Build') {
            steps {
                withMaven(maven: 'Maven 3.8.7') {
                    sh 'mvn clean package'
                }
            }
        }
        stage('Test') {
            steps {
                withMaven(maven: 'Maven 3.8.7') {
                    sh 'mvn test'
                }
            }
        }
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    withMaven(maven: 'Maven 3.8.7') {
                        sh 'mvn sonar:sonar -Dsonar.projectKey=maven-project -Dsonar.projectName=maven-project'
                    }
                }
            }
        }
        stage('Deploy') {
            steps {
                configFileProvider([configFile(fileId: '3dc4e145-c049-4115-a395-fcd626114de3', variable: 'MAVEN_SETTINGS')]) {
                    sh "mvn -s $MAVEN_SETTINGS tomcat7:deploy"
                }
            }
        }
    }
}