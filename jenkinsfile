pipeline {
    agent any
    stages {
        stage('Build') {
            steps {
                withMaven(maven: 'Maven 3.8.7') {
                    sh 'mvn clean package'
                }
            }
        }
        stage('Test') {
            steps {
                withMaven(maven: 'Maven 3.8.7') {
                    sh 'mvn test'
                }
            }
        }
        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    withMaven(maven: 'Maven 3.8.7') {
                        sh 'mvn clean verify sonar:sonar -Dsonar.projectKey=maven-project -Dsonar.projectName=maven-project'
                    }
                }
            }
        }
        stage('Deploy') {
            steps {
                withMaven(maven: 'Maven 3.8.7') {
                    sh 'mvn deploy'
                }
            }
        }
    }
}